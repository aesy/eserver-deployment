#!/usr/bin/env bash
set -euo pipefail

log() { printf '%s  %s\n' "$(date '+%F %T')" "$*"; }

CONTAINER="{{ minecraft_backup_container }}"
DATA_DIR="{{ minecraft_backup_data_dir }}"
LOCAL_DIR="{{ minecraft_backup_local_dir }}"
REMOTE="{{ minecraft_backup_remote }}"
BUCKET="{{ scaleway_bucket }}"
RCLONE_CONF_DIR="{{ rclone_data_root }}"
KEEP_WEEKLY="{{ minecraft_backup_keep_weekly }}"
KEEP_MONTHLY="{{ minecraft_backup_keep_monthly }}"
KEEP_YEARLY="{{ minecraft_backup_keep_yearly }}"

# gfs_keep_set WEEKLY MONTHLY YEARLY: stdin archive filenames -> stdout keep-set.
gfs_keep_set() {
  local keep_weekly="$1" keep_monthly="$2" keep_yearly="$3" sorted
  sorted="$(grep -E 'minecraft-[0-9]{4}-[0-9]{2}-[0-9]{2}\.tar\.gz' | sort -r)"
  [ -z "$sorted" ] && return 0
  {
    printf '%s\n' "$sorted" | head -n "$keep_weekly"
    printf '%s\n' "$sorted" \
      | awk -F'minecraft-' '{print substr($2,1,7)"\t"$0}' \
      | awk -F'\t' '!seen[$1]++ {print $2}' | head -n "$keep_monthly"
    printf '%s\n' "$sorted" \
      | awk -F'minecraft-' '{print substr($2,1,4)"\t"$0}' \
      | awk -F'\t' '!seen[$1]++ {print $2}' | head -n "$keep_yearly"
  } | sort -u
}

# gfs_delete_set WEEKLY MONTHLY YEARLY: stdin archive filenames -> stdout to-delete.
gfs_delete_set() {
  local all keep
  all="$(grep -E 'minecraft-[0-9]{4}-[0-9]{2}-[0-9]{2}\.tar\.gz' | sort -u)"
  [ -z "$all" ] && return 0
  keep="$(printf '%s\n' "$all" | gfs_keep_set "$@")"
  comm -23 <(printf '%s\n' "$all") <(printf '%s\n' "$keep")
}

mkdir -p "$LOCAL_DIR"
log "Starting minecraft backup"

# 1. Stop the server for a consistent, quiescent snapshot. The trap guarantees
#    it is restarted even if the archive step fails.
STOPPED=0
restart() { [ "$STOPPED" = "1" ] && docker start "$CONTAINER" || true; }
trap restart EXIT
log "Stopping $CONTAINER"
docker stop -t 60 "$CONTAINER"
STOPPED=1

# 2. Archive the full data directory.
archive="minecraft-$(date --utc +%Y-%m-%d).tar.gz"
log "Archiving $DATA_DIR -> $LOCAL_DIR/$archive"
tar czf "$LOCAL_DIR/$archive" -C "$DATA_DIR" .

# 3. Bring the server back up.
docker start "$CONTAINER"
STOPPED=0
log "Started $CONTAINER"

# 4. Prune local archives to the GFS keep-set.
delete_set="$(ls -1 "$LOCAL_DIR" | gfs_delete_set "$KEEP_WEEKLY" "$KEEP_MONTHLY" "$KEEP_YEARLY")"
while IFS= read -r name; do
  [ -n "$name" ] && log "Pruning $name" && rm -f "$LOCAL_DIR/$name"
done <<< "$delete_set"

# 5. Copy kept archives to Scaleway Glacier (rclone in a container).
log "Uploading to $REMOTE:$BUCKET/minecraft"
docker run --rm \
  -v "$LOCAL_DIR:/backups:ro" \
  -v "$RCLONE_CONF_DIR:/config/rclone:ro" \
  rclone/rclone copy /backups "$REMOTE:$BUCKET/minecraft" \
  --s3-storage-class=GLACIER --transfers=8 --size-only

# 6. Mirror the prune to Glacier.
while IFS= read -r name; do
  [ -n "$name" ] && docker run --rm \
    -v "$RCLONE_CONF_DIR:/config/rclone:ro" \
    rclone/rclone deletefile "$REMOTE:$BUCKET/minecraft/$name" || true
done <<< "$delete_set"

log "Backup complete: $archive"
