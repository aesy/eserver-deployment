entryPoints:
  web:
    address: :80
    http:
      redirections:
        entrypoint:
          to: web-secure
          scheme: https
          permanent: true
  web-secure:
    address: :443
    http:
      tls:
        certResolver: letsEncrypt
{% if acme_domain %}
        domains:
          - main: "{{ acme_domain }}"
            sans:
              - "*.{{ acme_domain }}"
{% endif %}

api:
  dashboard: true

providers:
  docker:
    network: web
    exposedByDefault: false

{% if acme_email %}
certificatesResolvers:
  letsEncrypt:
    acme:
      email: "{{ acme_email }}"
      storage: /etc/traefik/acme.json
      dnsChallenge:
        provider: "{{ acme_provider }}"
        delayBeforeCheck: 0
{% endif %}

global:
  checkNewVersion: false
  sendAnonymousUsage: false

log:
  level: INFO
